# ATLAS Pipeline Agent — Environment Variables
# Copy this to .env and fill in your credentials
# NEVER commit .env to git

# ── Salesforce ──────────────────────────────────────
SF_CLIENT_ID=
SF_CLIENT_SECRET=
SF_USERNAME=
SF_PASSWORD=
SF_SECURITY_TOKEN=
SF_DOMAIN=login

# ── Outreach ────────────────────────────────────────
OUTREACH_CLIENT_ID=
OUTREACH_CLIENT_SECRET=
OUTREACH_ACCESS_TOKEN=
OUTREACH_REFRESH_TOKEN=

# ── 6sense ──────────────────────────────────────────
SIXSENSE_API_KEY=

# ── Claude (Anthropic) ──────────────────────────────
ANTHROPIC_API_KEY=

# ── Microsoft Teams ─────────────────────────────────
TEAMS_WEBHOOK_URL=

# ── Agent Configuration ─────────────────────────────
# shadow = generate everything, send nothing (testing)
# review = human approves before sends (production default)
# auto   = fully autonomous (Month 3+ only)
# paused = full stop
ATLAS_MODE=shadow

# Max emails per day (ramp: 10 → 15 → 20 → 25)
ATLAS_DAILY_LIMIT=25

# Below this confidence → queue for human review
ATLAS_CONFIDENCE_THRESHOLD=0.85

# Run a cycle immediately on startup (good for testing)
ATLAS_RUN_ON_START=false
